OPENAI_API_KEY=<your_openai_api_key>
OPENAI_MODEL=gpt-5.4
ROUTER_MODEL=gpt-5.4-nano

# OAuth（選填，全部不設 = 無認證模式）

# server 端驗票：設 ISSUER + AUDIENCE 就啟用；REQUIRED_SCOPE 多一層 skill 授權
A2A_OIDC_ISSUER=https://your-idp/realms/xxx
A2A_OIDC_AUDIENCE=code-review-agent
A2A_REQUIRED_SCOPE=code_review.invoke

# client 端取票：SCOPE 要跟 server 的 REQUIRED_SCOPE 一致，否則被 403
A2A_OAUTH_TOKEN_URL=https://your-idp/realms/xxx/protocol/openid-connect/token
A2A_OAUTH_CLIENT_ID=your-client-id
A2A_OAUTH_CLIENT_SECRET=your-client-secret
A2A_OAUTH_SCOPE=code_review.invoke
